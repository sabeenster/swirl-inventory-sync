# Toast API (get from Toast Web → Integrations → Toast API access)
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_RESTAURANT_GUID=

# Shopify (get from Partners → Apps → Admin API)
SHOPIFY_STORE_DOMAIN=swirl-on-castro.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_LOCATION_ID=

# Resend (same key as wine enrichment agent)
RESEND_API_KEY=
ALERT_EMAIL_TO=sabeen@agentway.com
ALERT_EMAIL_FROM=swirl-sync@agentway.com

# Sync behavior
INVENTORY_BUFFER_PCT=0.10   # Hold back 10% to avoid oversells
DRY_RUN=false               # Set to true to test without writing to Shopify
